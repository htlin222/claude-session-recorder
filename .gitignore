# ── envs & caches ────────────────────────────────────────────────
# python venv (recreate: cd clip && uv venv .venv && uv pip install --python .venv/bin/python pillow numpy)
clip/.venv/
__pycache__/
*.pyc
.DS_Store

# ── regenerable scratch ──────────────────────────────────────────
# clip/intermediate/ is SHARED, disposable build scratch (overwritten every
# render); clip/dist/ is engine output staging. Both regenerate from the
# pipeline — the durable record of a finished clip lives in <slug>/build/.
clip/intermediate/
clip/dist/

# local backup snapshot (manual `cp`, not source)
clip_rsync/

# ── generated media ──────────────────────────────────────────────
# Heavy binaries regenerate from clip/lessons/<slug>/ via /clip or the pipeline.
# Product folders keep their TEXT record in git (manifest.md and
# build/{timeline,sync_report,jcut_report,verify}.json, build/config.toml,
# build/demo.tape, build/lesson/, build/PROVENANCE.md); the video/audio/player
# and raw logs are not committed.
*.mp4
*.mp3
*.srt
*.html
*.log

# experimental prototype scratch (regenerate by running the prototype)
clip/experimental/**/work/
clip/experimental/nvim/out.mp4
clip/experimental/nvim/code.py
mdp-demo/

# portable per-slug folders: scratch + vendored venv (regenerable)
*/intermediate/
engine/**/__pycache__/
engine/experimental/**/work/
engine/experimental/nvim/out.mp4
engine/experimental/nvim/code.py

# session-recorder scratch (one timeline per recording; regenerable)
engine/experimental/session-recorder/session-timeline.jsonl
engine/experimental/session-recorder/session-voiceover.*
engine/experimental/session-recorder/_seg/

# live/ recording sandboxes CONTAIN REAL CREDENTIALS (<demo>/.cfg/.credentials.json).
# Stage them under /tmp (outside the repo); this is a belt-and-suspenders guard
# in case one is ever created inside the tree. terminal.mp4 is covered by *.mp4.
.cfg/

# ── python packaging / test build outputs ────────────────────────
# session-recorder/live is pip-installable; these are throwaway build artifacts.
# Demo OUTPUT dirs (recordings, intermediate frames) live under /tmp, not the
# repo — see the .cfg/ note above.
*.egg-info/
build/
dist/
.pytest_cache/
